# OpenAI-Compatible LLM Configuration (Required for CV / Recipe / General agents)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# Telegram — required for Agent Hub webhook replies (see hub/main.py)
TELEGRAM_BOT_TOKEN=

# Optional — Weather Agent: if set, OpenWeatherMap is used; otherwise free Open-Meteo (no key)
# WEATHER_API_KEY=

# Optional — legacy multi-agent server (see server/app.py)
# TELEGRAM_WEBHOOK_SECRET=
# API_KEY_HEADER=
# CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:8000
