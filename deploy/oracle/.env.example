# Deploy settings for Oracle — this folder's .env (gitignored).
# Copy to ".env" and fill in:  cp .env.example .env

# Free hostname from https://duckdns.org (create one, point it at your VM IP).
DOMAIN=aihub.duckdns.org

# From your DuckDNS dashboard -> "token".
DUCKDNS_TOKEN=your-duckdns-token

# The part BEFORE .duckdns.org (e.g. for "aihub.duckdns.org" use "aihub").
DUCKDNS_SUBDOMAIN=aihub

# Timezone (duckdns sidecar + logs). Pick yours, e.g. Europe/Berlin, Asia/Karachi.
TZ=Europe/Berlin
